{
  "default_scan_dir": "",
  "default_report_dir": "",
  "recursive": true,
  "calculate_hash": true,
  "hash_algorithm": "SHA256",
  "big_file_threshold_mb": 100,
  "path_length_threshold": 180,
  "file_timeout_seconds": 15,
  "modified_time_months": 3,
  "detect_suspicious_extensions": true,
  "detect_double_extensions": true,
  "detect_hidden_files": true,
  "detect_empty_files": true,
  "detect_big_files": true,
  "detect_time_anomalies": true,
  "detect_long_paths": true,
  "ignored_dirs": [
    ".git",
    "__pycache__",
    "node_modules",
    ".venv",
    "venv"
  ],
  "skip_hidden_files": false,
  "skip_large_files_mb": 0,
  "skip_dirs": [
    "System Volume Information",
    "$RECYCLE.BIN",
    "Recovery",
    "Config.Msi"
  ],
  "skip_file_names": [],
  "skip_extensions": [
    ".key",
    ".pem",
    ".pfx",
    ".kdbx",
    ".wallet"
  ],
  "skip_path_keywords": [],
  "include_only_matched": false,
  "include_conflict_policy": "skip_wins",
  "include_extensions": [],
  "include_name_keywords": [],
  "include_path_keywords": [],
  "include_file_types": [],
  "export_full_paths": true,
  "suspicious_extensions": [
    ".bat",
    ".cmd",
    ".com",
    ".dll",
    ".exe",
    ".jse",
    ".lnk",
    ".msi",
    ".ps1",
    ".scr",
    ".vbe",
    ".vbs",
    ".wsf"
  ],
  "whitelisted_extensions": []
